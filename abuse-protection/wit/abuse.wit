package taika3d:lid;

interface abuse {
    /// Check if a request is within the rate limit.
    ///
    /// Parameters:
    ///   key         — identification key (e.g. user ID, IP address, email)
    ///   limit       — maximum number of requests allowed in the window
    ///   window-secs — duration of the sliding window in seconds
    ///
    /// Returns:
    ///   allowed     — true if request is allowed, false if rate limited
    ///   remaining   — number of requests remaining in the current window
    check-rate: async func(key: string, limit: u64, window-secs: u64) -> result<tuple<bool, u64>, string>;

    /// Record a metric event.
    record-metric: async func(name: string, labels: list<tuple<string, string>>) -> result<_, string>;
}

package taika3d:lid;

interface authority {
    /// Result of a region lookup
    record lookup-result {
        found: bool,
        region: option<string>,
    }

    /// Locate the region for a given email hash.
    /// This first checks the local region's persistent KV, 
    /// and if not found, broadcasts a cross-region NATS request.
    lookup: async func(email-hash: string) -> result<lookup-result, string>;
}

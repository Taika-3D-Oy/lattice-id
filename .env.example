# Lattice-ID local-prod environment
# Copy to .env and fill in real values.
# NEVER commit the .env file.

# AWS SES — create an IAM user with ONLY ses:SendEmail permission
SES_REGION=eu-west-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=noreply@yourdomain.com

# Superadmin — the first user to register with this email gets superadmin
SUPERADMIN_EMAIL=someone@yourdomain.com

# Internal auth secret — shared secret for cross-region /internal/* endpoints
INTERNAL_AUTH_SECRET=local-prod-secret-change-me
